# SONY Calendar — environment example
# Copy to .env and fill in real values. Never commit .env.

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# ── Gmail (service account + shared inbox) ──────────────────
# Workspace mailbox that internal team forwards emails to.
# The app polls this inbox every minute via the Gmail API.
GMAIL_USER=agent@naughtythings.com.hk
GMAIL_SA_EMAIL=
# Paste the full PEM, preserving line breaks. In Railway, use the raw
# multiline value or escape newlines as \n.
GMAIL_SA_PRIVATE_KEY=
# Required in production. Requests fail closed when this is missing.
# Send it in Authorization: Bearer <value> or x-poll-secret, never in the URL.
POLL_SECRET=
# Only envelope senders from these domains may trigger AI parsing. Comma-separated.
INBOUND_ALLOWED_DOMAINS=naughtythings.com.hk

# ── MiniMax (LLM — parser + copy drafter) ─────────────────
MINIMAX_API_KEY=
# Optional: override the model (default MiniMax-M3)
# MINIMAX_MODEL=MiniMax-M3

# ── Copy template (optional) ─────────────────────────────
COPY_TEMPLATE=

# ── App ────────────────────────────────────────────────────
APP_URL=http://localhost:3001
# Optional: set to 1 to disable the built-in Railway self-pinger.
# DISABLE_SELF_PING=1
