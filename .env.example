# SONY Calendar — environment example
# Copy to .env and fill in real values. Never commit .env.

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABA…KEY=
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

*** ── Gmail (shared agent inbox) ────────────────────────────
# Workspace mailbox that internal team forwards emails to.
# The app polls this inbox every minute and ingests new messages.
GMAIL_USER=agent@naughtythings.com.hk
# 16-char App Password from https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the mailbox.
GMAIL_APP_PASSWORD=
# Optional shared secret to lock down the /api/inbound/poll endpoint
POLL_SECRET=

# ── MiniMax (LLM — parser + copy drafter) ─────────────────
MINIMAX_API_KEY=
*** Optional: override the model (default MiniMax-M3)
# MINIMAX_MODEL=MiniMax-M3

# ── Copy template (optional) ─────────────────────────────
COPY_TEMPLATE=

# ── App ────────────────────────────────────────────────────
APP_URL=http://localhost:3001
